# Copy to .env and fill in. Never commit .env.

# Django
DJANGO_SECRET_KEY=replace-me-with-a-real-secret
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Postgres (matches docker-compose service)
DATABASE_URL=postgres://wiki:wiki@localhost:5432/wiki

# Redis (Celery broker + result backend)
REDIS_URL=redis://localhost:6379/0

# Readwise
# Get a token at https://readwise.io/access_token
READWISE_TOKEN=

# LLM (OpenAI-compatible — works with OpenAI, OpenRouter, Together, etc.)
LLM_API_KEY=
# Examples:
#   OpenAI:     https://api.openai.com/v1
#   OpenRouter: https://openrouter.ai/api/v1
LLM_BASE_URL=https://openrouter.ai/api/v1
# Recommended starting model (no default — explicit choice avoids surprise spend):
#   anthropic/claude-sonnet-4.6 (via OpenRouter)
#   gpt-4o-mini                  (via OpenAI)
LLM_MODEL=

# Wiki output
WIKI_OUTPUT_DIR=./wiki-project

# Pipeline tuning
CLASSIFICATION_BATCH_SIZE=15
SUMMARY_REGEN_THRESHOLD=5
TOPIC_FUZZY_MATCH_THRESHOLD=88
